# TVGSUOS — environment variables
# Copy to .env.local and fill in real values. Never commit .env.local.
#
# Same Supabase project as katiwala-owner-os- (project ref jbhfdmujqrtqkhacfegl) —
# this app reads/writes the existing database, it does not get its own.
# Every api/*.js function should be credential-gated (return a graceful
# {notConfigured: true, error: "..."} JSON response, not crash) when a key
# below is missing — same pattern as katiwala-owner-os-'s api/ directory.

# --- Supabase (KOS/TVGSUOS shared project) ---
# Public URL + anon key — safe to expose client-side, used by index.html directly.
SUPABASE_URL=https://jbhfdmujqrtqkhacfegl.supabase.co
SUPABASE_ANON_KEY=

# Server-side only. Never expose to the client. Used by api/*.js for
# privileged reads/writes (e.g. Daily Baseline Check upserts, signed
# storage URLs).
SUPABASE_SERVICE_ROLE_KEY=

# --- ODO's separate Supabase project ---
# Required for the Venture Updates panel's ODO status (api/odo-status.js,
# ported from katiwala-owner-os-'s api/generate-vera-status.js — reads
# vera_signals + health_snapshots from ODO's own project, not the shared
# KOS one above).
ODO_SUPABASE_SERVICE_ROLE_KEY=

# --- Anthropic (Ver's governance/AI functions) ---
ANTHROPIC_API_KEY=

# --- GitHub (optional) ---
# Raises API rate limits for any api/ function that reads repo content
# (e.g. grounding docs for an "Ask Ver" assistant, mirroring
# katiwala-owner-os-'s api/answer-ver-query.js). Required only if a repo
# this reads from goes private.
GITHUB_TOKEN=
